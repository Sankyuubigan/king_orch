{
  "productName": "King Orch",
  "version": "26.7.28",
  "identifier": "com.kingorch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "King Orch - Multi-Agent Studio",
        "width": 1100,
        "height": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "mcp_servers/*": "mcp_servers/",
      "../agents/": "agents/",
      "../models_catalog.json": "models_catalog.json"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCMEZGRUE5MUIxQjVGQzUKUldURlh4c2JxZjRQYS9Bc1hUckFGUmoxTnRoNGY1ZytROTRRbTF4T09aUnZCcDlBTzNRTkQydWoK",
      "endpoints": [
        "https://raw.githubusercontent.com/Sankyuubigan/king_orch/main/latest.json"
      ]
    }
  }
}