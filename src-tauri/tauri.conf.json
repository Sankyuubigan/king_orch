{
  "productName": "King Orch",
  "version": "26.5.31",
  "identifier": "com.kingorch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "King Orch - Multi-Agent Studio",
        "width": 1100,
        "height": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
      "mcp_servers/*"
    ],
    "externalBin": [
      "bin/yt-dlp",
      "bin/node"
    ]
  }
}